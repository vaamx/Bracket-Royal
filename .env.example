# ── Supabase (hosted project — create at supabase.com) ───────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only; NEVER expose to the client

# ── Live football data (football-data.org) ──────────────────────────────────
FOOTBALL_DATA_API_KEY=your-football-data-token

# ── Cron auth (Vercel crons send Authorization: Bearer $CRON_SECRET) ─────────
CRON_SECRET=long-random-string

# ── Web Push (VAPID) — generate: npx web-push generate-vapid-keys ────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ── Email for match reminders/results (optional). We use SendGrid. ───────────
# (Sign-in / magic-link emails are sent by Supabase Auth SMTP, configured in
#  the Supabase dashboard — set that to SendGrid too.)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
NOTIFY_EMAIL_FROM=Bracket Royale <noreply@yourdomain.com>
